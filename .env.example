# Copy to .env in the project root or backend/ (both are loaded; backend/.env wins on conflicts).
# 
# Use a single line, no quotes needed:
# OPENAI_API_KEY=sk-proj-...
#
# Optional — defaults to gpt-4o-mini if unset
# OPENAI_MODEL=gpt-4o-mini
#
# Optional — enables OpenRouteService travel-time checks between destinations
# OPENROUTESERVICE_API_KEY=your_openrouteservice_key
# Optional — DRIVE by default. Supported values here: DRIVE, WALK, BICYCLE
# OPENROUTESERVICE_TRAVEL_MODE=DRIVE
#
# Weather tool (backend/weather_tool.py) uses Open-Meteo — no API key required.
